PORT=3000
# BPP Persona (for P2P Trading)
# Controls which persona responses are used for P2P Trading domain.
# Options:
#   - 'bpp' = Regular P2P Trading BPP responses
#   - 'utility-bpp' = Utility BPP responses (for cascaded flows)
#   - (unset/empty) = Default behavior, backward compatible
# PERSONA=bpp

# Base URL the BPP-side webhook posts on_<action> callbacks to (e.g. http://host.docker.internal:3000/bpp/caller).
# If unset, the callback URL is derived from context.bpp_uri/bpp_url in each request.
# BPP_CALLBACK_ENDPOINT=

# Alternate root directory for structured response fixtures (webhook/responses layout).
# If unset, defaults to ./internal/webhook/responses.
# RESPONSE_FIXTURES_BASE_PATH=
