PORT=3000

# Log verbosity: debug | info | warn | error (default: info)
# LOG_LEVEL=info
# BPP Persona (for P2P Trading)
# Controls which persona responses are used for P2P Trading domain.
# Options:
#   - 'bpp' = Regular P2P Trading BPP responses
#   - 'utility-bpp' = Utility BPP responses (for cascaded flows)
#   - (unset/empty) = Default behavior, backward compatible
# PERSONA=bpp

# Base URL the BPP-side webhook posts on_<action> callbacks to (e.g. http://host.docker.internal:3000/bpp/caller).
# If unset, the callback URL is derived from context.bpp_uri/bpp_url in each request.
# BPP_CALLBACK_ENDPOINT=

# Base URL (GitHub raw content) pointing at whatever directory directly contains the
# sector folders (trade/, hospitality/, ...). Does NOT need to mirror this repo's
# internal/webhook/responses path -- point it at wherever the sector folders live in the
# target repo, e.g. https://raw.githubusercontent.com/<org>/<repo>/<branch>/responses
# If unset, structured fixture lookup is skipped and only the legacy local jsons/ fallback is used.
# RESPONSE_FIXTURES_BASE_URL=
